# Application
APP_NAME=Marspedia
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://webtopup.imtaqin.id

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=webtopup_database
DB_USERNAME=webtopup_user
DB_PASSWORD=your_secure_password

# Cache & Session
CACHE_STORE=file
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Queue
QUEUE_CONNECTION=database

# Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@webtopup.imtaqin.id
MAIL_FROM_NAME="${APP_NAME}"

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Broadcasting
BROADCAST_CONNECTION=log

# Apigames API Configuration
APIGAMES_BASE_URL=https://api.example.com
APIGAMES_MERCHANT_ID=your_apigames_merchant_id
APIGAMES_SECRET_KEY=your_apigames_secret_key
APIGAMES_TIMEOUT=30

# Midtrans Payment Gateway
MIDTRANS_SERVER_KEY=your_midtrans_server_key
MIDTRANS_CLIENT_KEY=your_midtrans_client_key
MIDTRANS_ENVIRONMENT=production
MIDTRANS_SANITIZED=true
MIDTRANS_3DS=true

# WhatsApp Notification
WHATSAPP_PROVIDER=fonnte
# Fonnte Configuration
WHATSAPP_FONNTE_API_KEY=your_fonnte_api_key
WHATSAPP_FONNTE_SENDER=6281234567890
# Wablas Configuration (if using wablas)
WHATSAPP_WABLAS_API_KEY=your_wablas_api_key
WHATSAPP_WABLAS_DOMAIN=your_domain.wablas.com
WHATSAPP_WABLAS_SENDER=6281234567890

# Vite
VITE_APP_NAME="${APP_NAME}"
